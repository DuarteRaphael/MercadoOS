{
  "files": [],
  "references": [
    { "path": "apps/web" },
    { "path": "apps/api" },
    { "path": "packages/ui" },
    { "path": "packages/auth" },
    { "path": "packages/database" },
    { "path": "packages/config" },
    { "path": "packages/validation" },
    { "path": "packages/types" },
    { "path": "packages/utils" }
  ],
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "jsx": "preserve",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "incremental": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@mercados/*": ["packages/*/src"]
    }
  }
}
